<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  FocusNotch is distributed outside the Mac App Store (direct download /
	  notarized DMG) so it can run the Shortcuts CLI to toggle Do Not Disturb.
	  App Sandbox is therefore disabled.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
